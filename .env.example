# Finnhub API Key
# Get your free API key at: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Vercel KV (for caching and API key storage)
# These are automatically set by Vercel when you add KV storage
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_URL=

# Cron Secret (for securing cron endpoints)
# Generate a random secret: openssl rand -base64 32
CRON_SECRET=your_random_secret_here

# Stripe (for payments - optional for MVP)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# NextAuth (for user authentication - optional for MVP)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
